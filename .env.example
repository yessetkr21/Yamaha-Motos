# Copy this file to .env and fill with your Mercado Pago credentials
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows CMD)

# Mercado Pago access token (TEST-... for sandbox or APP_USR-... for production)
MERCADOPAGO_ACCESS_TOKEN=

# Frontend URL that Mercado Pago will redirect to after checkout
PAYMENTS_FRONTEND_BASE_URL=http://localhost:8000

# 1 = use sandbox checkout URL (recommended only with TEST- token), 0 = production checkout URL
MERCADOPAGO_USE_SANDBOX=1

# 1 = simulated gateway (/pasarela-demo), 0 = real Mercado Pago API
PAYMENTS_DEMO_MODE=0
